import os
import sys
import urllib.parse
import tkinter as tk
from tkinter import messagebox

class UserInterface:

    def __init__(self):
        self.urlText = ""

    def normalize_url(self, url: str) -> str | None:
        """Normalize and validate a URL string.

        Returns a normalized URL (with scheme) if valid, otherwise None.
        """
        if not url:
            return None
        url = url.strip()
        # Reject whitespace-containing strings
        if " " in url:
            return None

        parsed = urllib.parse.urlparse(url)
        # If no scheme, assume http and reparse
        if not parsed.scheme:
            url = "http://" + url
            parsed = urllib.parse.urlparse(url)

        if parsed.scheme not in ("http", "https"):
            return None

        # Must have network location
        if not parsed.netloc:
            return None

        # Basic hostname check
        if "." not in parsed.netloc and parsed.hostname is None:
            return None

        # Rebuild and return normalized URL
        return urllib.parse.urlunparse(parsed)

    
    def create_GUI(self):
        # Attempt to create the Tk window; let TclError indicate headless failure.
        try:
            window = tk.Tk()
        except tk.TclError:
            print("Unable to create Tk window (no display).")
            # Fall back to a command-line interface when GUI isn't available
            self.cli_fallback()
            return
        window.title("Url Shortener")
        window.geometry("300x300")
        window.resizable(False, False)

        instructions = tk.Label(
            window,
            text="Type the URL you want below.",
            font=("Segoe UI", 10),
            wraplength=10,
            justify="center"
        )
        instructions.pack()

        url_frame = tk.Frame(window)
        url_frame.pack(pady=10)

        tk.Label(url_frame, text="URL: ", anchor="w").grid(row=0, column=0, sticky="w", pady=6)
        self.url_entry = tk.Entry(url_frame, width=50)
        self.url_entry.grid(row=0, column=1, pady=6)

        button_frame = tk.Frame(window)
        button_frame.pack(pady=10)

        self.info_label = tk.Label(window, text="", font=("Segoe UI", 10), fg="green", wraplength=420, justify="center")
        self.info_label.pack(pady=(8, 0))

        

        window.mainloop()

    def cli_fallback(self):
        """Simple command-line fallback. Uses `UrlShortener` if available.

        If stdin is not interactive, prints a brief instruction and returns.
        """
        print("Entering command-line fallback mode.")

        if not sys.stdin.isatty():
            print("No interactive terminal available. Run this script in a terminal to use CLI mode.")
            return

        try:
            from UrlShortener import UrlShortener
            shortener = UrlShortener("https://test")
        except Exception:
            shortener = None

        while True:
            try:
                url = input("Enter URL to shorten, or ask for data on an existing short url (or 'q' to quit): ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                break
            if not url or url.lower() in ("q", "quit", "exit"):
                break
            # Support 'data' command to fetch metadata for a short URL
            if url.lower() == "data":
                try:
                    key = input("Enter short URL or short code: ").strip()
                except (EOFError, KeyboardInterrupt):
                    print()
                    break
                if not key:
                    print("No input provided.")
                    continue
                # Normalize candidate short URL
                candidate = key.rstrip('/')
                if '/' not in candidate:
                    candidate = f"{shortener.domain}/{candidate}"
                record = None
                try:
                    record = shortener.get_record(candidate)
                except Exception as e:
                    print("Error fetching record:", e)
                    continue
                if not record:
                    print("No record found for:", candidate)
                else:
                    print("Record metadata:")
                    for k, v in record.items():
                        print(f"  {k}: {v}")
                continue

            if shortener:
                try:
                    # Try to detect a short URL or short code and expand it first.
                    expanded = None
                    input_str = url.rstrip('/')
                    # If the input starts with the shortener domain, treat it as a short URL.
                    if input_str.startswith(shortener.domain):
                        expanded = shortener.access_url(input_str)
                    else:
                        # If the input looks like a short code (no slash, short-ish), try to expand.
                        if '/' not in input_str and 1 <= len(input_str) <= 32:
                            candidate = f"{shortener.domain}/{input_str}"
                            expanded = shortener.access_url(candidate)

                    if expanded:
                        print("Long URL:", expanded)
                    else:
                        # Validate and normalize the URL before shortening.
                        normalized = self.normalize_url(url)
                        if not normalized:
                            print("Invalid URL. Please enter a valid http(s) URL (e.g. https://example.com).")
                            continue
                        short = shortener.shorten(normalized)
                        print("Short URL:", short)
                except Exception as e:
                    print("Error:", e)
            else:
                print("No UrlShortener available; you entered:", url)

        print("Exiting CLI fallback.")

def main():
    user = UserInterface()
    user.create_GUI()

if __name__ == "__main__":
    main()
